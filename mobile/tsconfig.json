{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Resolve @openmes/ui's twin-platform files to the .native.tsx variant,
    // mirroring Metro — so the shared package typechecks under strict mode.
    "moduleSuffixes": [".native", ""],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
