APP_NAME=OpenMES
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=openmmes
DB_USERNAME=openmmes_user
DB_PASSWORD=openmmes_secret

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

# Reverb (WebSocket server) — defaults work inside docker compose.
#
# Production checklist:
#   1. REVERB_HOST = the public hostname clients reach the WebSocket on
#      (usually the same host as APP_URL).
#   2. Generate a real REVERB_APP_SECRET. The default below is INSECURE —
#      anyone with it can broadcast arbitrary events. Example:
#        php -r "echo bin2hex(random_bytes(24));"
#   3. For HTTPS deployments set REVERB_SCHEME=https. Caddy terminates TLS
#      in front of /app/* and /apps/* (its automatic Let's Encrypt pipeline
#      handles WebSocket upgrades transparently — no extra Caddyfile config).
#   4. REVERB_SERVER_HOST stays 0.0.0.0 so the container binds all
#      interfaces; the proxy is the only thing that should reach it.
REVERB_APP_ID=openmes
REVERB_APP_KEY=openmes-app-key
REVERB_APP_SECRET=openmes-app-secret-change-me
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# ── Multi-instance Reverb (scale-out) ─────────────────────────────────────
# Single-container deploys (the default docker-compose stack) work fine
# without these. Set them ONLY when you run multiple `reverb` replicas
# behind a load balancer — Reverb uses Redis pub/sub to fan broadcasts
# across instances.
#
# REVERB_SCALING_ENABLED=true
# REVERB_SCALING_CHANNEL=reverb
# REDIS_HOST=redis            # add a `redis: image: redis:7-alpine` service
# REDIS_PORT=6379
# REDIS_PASSWORD=
#
# Then in docker-compose.yml, add `replicas: 3` (or however many) to the
# reverb service and put a TCP load balancer in front of port 8080.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum SPA stateful domains (same-origin React app)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:80,127.0.0.1,127.0.0.1:8000
